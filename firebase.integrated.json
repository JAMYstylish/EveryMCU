{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "integrated-app",
    "ignore": ["firebase.integrated.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|webmanifest)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
