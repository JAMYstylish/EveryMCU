{
  "rules": {
    ".read": false,
    ".write": false,
    "everymcuIntegrated": {
      "nicknameClaims": {
        "$nickname": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email != null && newData.child('authMethod').val() === 'password' && newData.child('ownerUid').val() === auth.uid && newData.child('email').val() === auth.token.email",
          ".validate": "newData.hasChildren(['authMethod', 'email', 'ownerUid', 'nickname', 'updatedAt'])"
        }
      },
      "users": {
        "$nickname": {
          ".read": "auth != null && root.child('everymcuIntegrated/nicknameClaims/' + $nickname + '/ownerUid').val() === auth.uid",
          ".write": "auth != null && root.child('everymcuIntegrated/nicknameClaims/' + $nickname + '/ownerUid').val() === auth.uid"
        }
      },
      "community": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "everymcuWeeklyStatus": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
